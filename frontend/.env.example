# Production Frontend .env Template
# Copy values dari local .env setelah backend di-deploy ke Vercel
# Format: VITE_API_URL=https://backend-name.vercel.app/api

# Development (local):
# VITE_API_URL=http://localhost:5000/api

# Production (after backend deployed):
VITE_API_URL=https://your-backend-name.vercel.app/api
